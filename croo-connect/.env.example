# CROO Agent Store credentials — register at https://agent.croo.network
# (My Agents -> Register Agent -> copy the API key; it is shown only ONCE).
# Leave empty to run the provider in dry-run mode.
CROO_SDK_KEY=

# CROO endpoints (defaults, rarely changed)
# CROO_API_URL=https://api.croo.network
# CROO_WS_URL=wss://api.croo.network/ws

# Where this provider reaches the Hook AI backend.
# Under docker compose this is set to http://api:8000 automatically.
# HOOKAI_API_URL=http://localhost:8000

# For the requester demo (npm run buy): the PROVIDER's service id from the dashboard.
# CROO_TARGET_SERVICE_ID=
