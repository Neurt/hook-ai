# ── Hook AI / OpenRouter ────────────────────────────────────────────────
# Copy this file to ".env" and fill in your key.  (.env is git-ignored.)

# REQUIRED. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# Model slug. NOTE: availability changes over time — this default may or may not
# be live. Pick a current slug at https://openrouter.ai/models
# (e.g. an OpenAI / Anthropic / Google / Meta model). Format is "vendor/model".
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Optional ────────────────────────────────────────────────────────────
# Base URL (rarely changed)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# App-attribution headers used by OpenRouter's rankings (optional, non-functional)
# OPENROUTER_REFERER=https://your-app.example
# OPENROUTER_TITLE=Hook AI

# Generation tuning
# HOOKAI_TEMPERATURE=0.4
# HOOKAI_MAX_TOKENS=1500
# HOOKAI_TIMEOUT=60

# ── Jooble job search (optional — live international job discovery) ────────
# Free key: https://jooble.org/api/about (emailed after signup). ~50+ countries,
# targeted via the search location. Free-tier rate limits are unpublished.
# JOOBLE_API_KEY=your_jooble_key

# Adzuna (legacy — cv-playground CLIs only; the server no longer reads these)
# ADZUNA_APP_ID=your_app_id
# ADZUNA_APP_KEY=your_app_key
# ADZUNA_COUNTRY=gb

# ── Hunter.io contact lookup (optional — real hiring emails for draft_email.py) ──
# Free key (25 searches/mo): https://hunter.io/api-keys
# HUNTER_API_KEY=your_hunter_key
# When Hunter's monthly quota is spent (or no key is set), contact lookup falls back
# to keyless web search via SEARXNG_URL (set in docker-compose): it extracts a public
# careers/recruiting email from search results, keeping the source page for provenance.
# Free and unquota'd, but lower hit-rate than Hunter — see docs.
